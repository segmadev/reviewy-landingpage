                  "    pm.test('Conversation ID returned', function() {",
                  "        pm.expect(json.conversationId).to.not.be.empty;",
                  "    });",
                  "    pm.test('Items is a non-empty array', function() {",
                  "        pm.expect(json.items).to.be.an('array').that.is.not.empty;",
                  "    });",
                  "    pm.test('Field name matches request', function() {",
                  "        pm.expect(json.fieldName).to.equal('workExperience');",
